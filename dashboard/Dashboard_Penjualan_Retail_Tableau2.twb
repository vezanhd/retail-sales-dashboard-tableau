      <aliases enabled='yes' />
      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_3437073839943680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_3437073844604931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Kategori] : SUM([Sales]) / COUNTD([ID Transaksi]) }' />
      </column>
      <column caption='AOV per Kategori' datatype='real' name='[Calculation_3437073845698564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Kategori] : SUM([Sales]) / COUNTD([ID Transaksi]) }' />
      </column>
      <column caption='Status Profit' datatype='string' name='[Calculation_3437073846423557]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &gt; 5000000 THEN &quot;Profit Tinggi&quot;&#13;&#10;ELSEIF [Profit] &gt; 1000000 THEN &quot;Profit Sedang&quot;&#13;&#10;ELSE &quot;Profit Rendah&quot;&#13;&#10;END' />
      </column>
